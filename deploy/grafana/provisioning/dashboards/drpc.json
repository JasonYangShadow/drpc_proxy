            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "sum(drpc_worker_dlq_sent_total)",
                    "legendFormat": "dlq",
                    "refId": "A"
                }
            ]
        },
        {
            "id": 20,
            "type": "stat",
            "title": "Queue Full (dropped)",
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": {
                "x": 0,
                "y": 4,
                "w": 4,
                "h": 4
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "red",
                                "value": 1
                            }
                        ]
                    }
                }
            },
            "options": {
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ]
                },
                "colorMode": "background",
                "graphMode": "area"
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "sum(drpc_proxy_queue_full_total)",
                    "legendFormat": "dropped",
                    "refId": "A"
                }
            ]
        },
        {
            "id": 7,
            "type": "timeseries",
            "title": "Request Rate",
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": {
                "x": 0,
                "y": 4,
                "w": 12,
                "h": 8
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "reqps",
                    "custom": {
                        "lineWidth": 2
                    }
                },
                "overrides": []
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "sum(rate(drpc_proxy_requests_total[$__rate_interval]))",
                    "legendFormat": "total",
                    "refId": "A"
                },
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "rate(drpc_proxy_requests_total[$__rate_interval])",
                    "legendFormat": "{{instance}}",
                    "refId": "B"
                }
            ]
        },
        {
            "id": 8,
            "type": "timeseries",
            "title": "Kafka Throughput",
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": {
                "x": 12,
                "y": 4,
                "w": 12,
                "h": 8
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "short/s",
                    "custom": {
                        "lineWidth": 2
                    }
                },
                "overrides": [
                    {
                        "matcher": {
                            "id": "byName",
                            "options": "errors/s"
                        },
                        "properties": [
                            {
                                "id": "color",
                                "value": {
                                    "mode": "fixed",
                                    "fixedColor": "red"
                                }
                            }
                        ]
                    }
                ]
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "sum(rate(drpc_proxy_kafka_sent_total[$__rate_interval]))",
                    "legendFormat": "sent/s",
                    "refId": "A"
                },
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "sum(rate(drpc_proxy_kafka_errors_total[$__rate_interval]))",
                    "legendFormat": "errors/s",
                    "refId": "B"
                }
            ]
        },
        {
            "id": 9,
            "type": "timeseries",
            "title": "Worker \u2014 Messages/s",
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": {
                "x": 0,
                "y": 12,
                "w": 12,
                "h": 8
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "short/s",
                    "custom": {
                        "lineWidth": 2
                    }
                },
                "overrides": [
                    {
                        "matcher": {
                            "id": "byName",
                            "options": "success/s"
                        },
                        "properties": [
                            {
                                "id": "color",
                                "value": {
                                    "mode": "fixed",
                                    "fixedColor": "green"
                                }
                            }
                        ]
                    },
                    {
                        "matcher": {
                            "id": "byName",
                            "options": "failure/s"
                        },
                        "properties": [
                            {
                                "id": "color",
                                "value": {
                                    "mode": "fixed",
                                    "fixedColor": "red"
                                }
                            }
                        ]
                    }
                ]
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "sum(rate(drpc_worker_messages_processed_total{status=\"success\"}[$__rate_interval]))",
                    "legendFormat": "success/s",
                    "refId": "A"
                },
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "sum(rate(drpc_worker_messages_processed_total{status=\"failure\"}[$__rate_interval]))",
                    "legendFormat": "failure/s",
                    "refId": "B"
                }
            ]
        },
        {
            "id": 10,
            "type": "timeseries",
            "title": "Worker \u2014 Processing Latency",
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": {
                "x": 12,
                "y": 12,
                "w": 12,
                "h": 8
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "s",
                    "custom": {
                        "lineWidth": 2
                    }
                },
                "overrides": []
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "histogram_quantile(0.50, sum(rate(drpc_worker_processing_duration_seconds_bucket[$__rate_interval])) by (le))",
                    "legendFormat": "p50",
                    "refId": "A"
                },
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "histogram_quantile(0.95, sum(rate(drpc_worker_processing_duration_seconds_bucket[$__rate_interval])) by (le))",
                    "legendFormat": "p95",
                    "refId": "B"
                },
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "histogram_quantile(0.99, sum(rate(drpc_worker_processing_duration_seconds_bucket[$__rate_interval])) by (le))",
                    "legendFormat": "p99",
                    "refId": "C"
                }
            ]
        },
        {
            "id": 11,
            "type": "timeseries",
            "title": "Per-Instance \u2014 Request Rate",
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": {
                "x": 0,
                "y": 20,
                "w": 12,
                "h": 8
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "reqps",
                    "custom": {
                        "lineWidth": 2
                    }
                },
                "overrides": []
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "rate(drpc_proxy_requests_total[$__rate_interval])",
                    "legendFormat": "{{instance}}",
                    "refId": "A"
                }
            ]
        },
        {
            "id": 12,
            "type": "timeseries",
            "title": "Worker \u2014 Avg Duration & DLQ Rate",
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": {
                "x": 12,
                "y": 20,
                "w": 12,
                "h": 8
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "s",
                    "custom": {
                        "lineWidth": 2
                    }
                },
                "overrides": [
                    {
                        "matcher": {
                            "id": "byName",
                            "options": "dlq/s"
                        },
                        "properties": [
                            {
                                "id": "custom.axisPlacement",
                                "value": "right"
                            },
                            {
                                "id": "unit",
                                "value": "short/s"
                            },
                            {
                                "id": "color",
                                "value": {
                                    "mode": "fixed",
                                    "fixedColor": "orange"
                                }
                            }
                        ]
                    }
                ]
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "sum(rate(drpc_worker_processing_duration_seconds_sum[$__rate_interval])) / sum(rate(drpc_worker_processing_duration_seconds_count[$__rate_interval]))",
                    "legendFormat": "avg duration",
                    "refId": "A"
                },
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "sum(rate(drpc_worker_dlq_sent_total[$__rate_interval]))",
                    "legendFormat": "dlq/s",
                    "refId": "B"
                }
            ]
        }
    ]
}