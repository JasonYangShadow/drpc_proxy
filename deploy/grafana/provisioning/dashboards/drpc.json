{
    "title": "DRPC Proxy",
    "uid": "drpc-proxy-overview",
    "version": 1,
    "schemaVersion": 39,
    "refresh": "5s",
    "time": {
        "from": "now-15m",
        "to": "now"
    },
    "panels": [
        {
            "id": 1,
            "title": "Proxy — Request Rate",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 0
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "reqps",
                    "custom": {
                        "lineWidth": 2
                    }
                }
            },
            "targets": [
                {
                    "expr": "sum(rate(drpc_proxy_requests_total[$__rate_interval]))",
                    "legendFormat": "requests/s",
                    "refId": "A"
                }
            ]
        },
        {
            "id": 2,
            "title": "Proxy — Kafka Sent Rate",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 0
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "reqps",
                    "custom": {
                        "lineWidth": 2
                    }
                }
            },
            "targets": [
                {
                    "expr": "sum(rate(drpc_proxy_kafka_sent_total[$__rate_interval]))",
                    "legendFormat": "sent/s",
                    "refId": "A"
                },
                {
                    "expr": "sum(rate(drpc_proxy_kafka_errors_total[$__rate_interval]))",
                    "legendFormat": "errors/s",
                    "refId": "B"
                }
            ]
        },
        {
            "id": 3,
            "title": "Worker — Messages Processed per Second",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 8
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "reqps",
                    "custom": {
                        "lineWidth": 2
                    }
                }
            },
            "targets": [
                {
                    "expr": "sum(rate(drpc_worker_messages_processed_total{status=\"success\"}[$__rate_interval]))",
                    "legendFormat": "success/s",
                    "refId": "A"
                },
                {
                    "expr": "sum(rate(drpc_worker_messages_processed_total{status=\"failure\"}[$__rate_interval]))",
                    "legendFormat": "failure/s",
                    "refId": "B"
                }
            ]
        },
        {
            "id": 4,
            "title": "Worker — Processing Duration (p50 / p95 / p99)",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 8
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "s",
                    "custom": {
                        "lineWidth": 2
                    }
                }
            },
            "targets": [
                {
                    "expr": "histogram_quantile(0.50, sum(rate(drpc_worker_processing_duration_seconds_bucket[$__rate_interval])) by (le))",
                    "legendFormat": "p50",
                    "refId": "A"
                },
                {
                    "expr": "histogram_quantile(0.95, sum(rate(drpc_worker_processing_duration_seconds_bucket[$__rate_interval])) by (le))",
                    "legendFormat": "p95",
                    "refId": "B"
                },
                {
                    "expr": "histogram_quantile(0.99, sum(rate(drpc_worker_processing_duration_seconds_bucket[$__rate_interval])) by (le))",
                    "legendFormat": "p99",
                    "refId": "C"
                }
            ]
        },
        {
            "id": 5,
            "title": "Worker — DLQ Rate",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 16
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "reqps",
                    "custom": {
                        "lineWidth": 2
                    }
                }
            },
            "targets": [
                {
                    "expr": "sum(rate(drpc_worker_dlq_sent_total[$__rate_interval]))",
                    "legendFormat": "dlq/s",
                    "refId": "A"
                }
            ]
        },
        {
            "id": 6,
            "title": "Worker — Average Processing Duration",
            "type": "stat",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 16
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "s",
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 1
                            },
                            {
                                "color": "red",
                                "value": 3
                            }
                        ]
                    }
                }
            },
            "targets": [
                {
                    "expr": "sum(rate(drpc_worker_processing_duration_seconds_sum[$__rate_interval])) / sum(rate(drpc_worker_processing_duration_seconds_count[$__rate_interval]))",
                    "legendFormat": "avg duration",
                    "refId": "A"
                }
            ]
        }
    ]
}