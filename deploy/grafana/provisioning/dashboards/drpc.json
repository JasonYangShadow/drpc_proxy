            },
            "options": {
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ]
                },
                "colorMode": "background",
                "graphMode": "area"
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "sum(drpc_worker_messages_processed_total{status=\"success\"})",
                    "legendFormat": "success",
                    "refId": "A"
                }
            ]
        },
